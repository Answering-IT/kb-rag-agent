# AWS WebSocket Configuration
# WebSocket URL for direct connection to AWS Agent (Agent V2 - Agent Core Runtime)
# Get from infrastructure deployment outputs
NEXT_PUBLIC_WS_URL=wss://0wyp9wnba7.execute-api.us-east-1.amazonaws.com/dev

# REST Streaming API (Lambda Function URL with RESPONSE_STREAM)
# Alternative to WebSocket for streaming responses
NEXT_PUBLIC_STREAMING_API_URL=https://elgoe2eluevfh2kpte4dyuttji0romxw.lambda-url.us-east-1.on.aws/

# Chat mode: 'websocket' or 'streaming' (default: websocket)
# websocket = Uses WebSocket API with bidirectional connection
# streaming = Uses REST API with response streaming
NEXT_PUBLIC_CHAT_MODE=websocket

# Show connection mode selector (default: false, always true on /test page)
# Set to 'true' to show REST/WebSocket toggle on all pages
# Set to 'false' to hide on production pages (still visible on /test)
NEXT_PUBLIC_SHOW_MODE_SELECTOR=false

# Language: 'es' or 'en' (default: es)
# es = Spanish (Español)
# en = English
NEXT_PUBLIC_LANGUAGE=es
